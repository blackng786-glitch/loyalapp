# ── SUPABASE ────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY   # Settings → API → service_role (NOT anon)
SUPABASE_ANON_KEY=YOUR_ANON_KEY              # Settings → API → anon public

# ── WEB PUSH (VAPID) ────────────────────────────────────────
# Generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
CONTACT_EMAIL=your@email.com

# ── APP ─────────────────────────────────────────────────────
PORT=3000
APP_URL=https://your-app.railway.app        # Your Railway URL after deploy
